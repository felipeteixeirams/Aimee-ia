{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "cleanUrls": true,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
