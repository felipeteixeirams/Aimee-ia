{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --platform=node --bundle --packages=external --format=esm --outfile=dist-server/server.js --alias:@=./src",
    "build": "node scripts/build-orch.js",
    "preview": "vite preview",
    "start": "node dist-server/server.js",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "sync-env": "tsx scripts/sync-env.ts",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production' && !process.env.CI) { try { require('child_process').execSync('husky', { stdio: 'inherit' }) } catch (e) {} }\""
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/middie": "^9.3.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/nodemailer": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "fastify": "^5.8.5",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.10.0",
    "googleapis": "^171.4.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.0",
    "lru-cache": "^11.3.6",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.6",
    "openai": "^6.36.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^3.5.0",
    "tsyringe": "^4.10.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "husky": "^9.1.7",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
