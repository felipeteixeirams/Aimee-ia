# =========================================================================
# AIMEE - ARQUIVO DE EXEMPLO DE CONFIGURAÇÃO (.env)
# =========================================================================
# Este arquivo contém todas as variáveis necessárias para o funcionamento
# pleno da Aimee. Copie este arquivo para um novo chamado '.env' e
# preencha os valores conforme as instruções abaixo.
# =========================================================================

# -------------------------------------------------------------------------
# 1. NÚCLEO DE INTELIGÊNCIA ARTIFICIAL (LLMs)
# -------------------------------------------------------------------------
# O sistema utiliza uma estratégia de redundância. É obrigatório configurar
# ao menos UMA dessas chaves. A Gemini é a recomendada como primária.
#
# Onde obter:
# - Gemini: https://aistudio.google.com/app/apikey
# - OpenAI: https://platform.openai.com/api-keys
# - DeepSeek: https://platform.deepseek.com/api_keys
# - Anthropic: https://console.anthropic.com/settings/keys

GEMINI_API_KEY=""
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
ANTHROPIC_API_KEY=""

# -------------------------------------------------------------------------
# 2. BANCO DE DADOS E AUTENTICAÇÃO (FIREBASE)
# -------------------------------------------------------------------------
# Utilizado para persistência de dados, perfis de usuários e regras de segurança.
# Começam com VITE_ pois são expostas ao frontend.
#
# Onde obter:
# - Vá em https://console.firebase.google.com/
# - Configurações do Projeto > Seus Aplicativos > Configurações do SDK (Config)

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="aimee-db9b3.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="aimee-db9b3"
VITE_FIREBASE_STORAGE_BUCKET="aimee-db9b3.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="317073273380"
VITE_FIREBASE_APP_ID="1:317073273380:web:c87faeeaf141201e5c1eb1"
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_DATABASE_ID="ai-studio-a42d197f-b2fd-4ea3-b5d9-b3b02ea6b201"

# -------------------------------------------------------------------------
# 2.1 FIREBASE ADMIN (SERVER-SIDE)
# -------------------------------------------------------------------------
# Utilizado para operações administrativas no servidor (ex: CRUD de usuários).

FIREBASE_PROJECT_ID="aimee-db9b3"
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# -------------------------------------------------------------------------
# 3. COMUNICAÇÃO E ALERTAS (SMTP / E-MAIL)
# -------------------------------------------------------------------------
# Necessário para enviar e-mails de suporte, aprovação de contas e alertas críticos.
#
# Dica para Gmail: 
# - Use SMTP_HOST="smtp.gmail.com" e SMTP_PORT=587.
# - Em SMTP_PASS, utilize uma "Senha de App" gerada na sua conta Google.

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
ADMIN_EMAIL="felipeteixeirams@gmail.com"

# -------------------------------------------------------------------------
# 4. INTEGRAÇÕES GOOGLE (OAUTH & MAPS)
# -------------------------------------------------------------------------
# Necessário para integração com Google Calendar e exibição de mapas.
#
# Onde obter:
# - Google Cloud Console: https://console.cloud.google.com/apis/credentials
# - Crie um "ID do cliente OAuth 2.0" (Tipo: Aplicativo Web).
# - O REDIRECT_URI deve ser: https://seu-dominio.com/api/auth/google/callback

GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""
VITE_GOOGLE_MAPS_API_KEY=""

# -------------------------------------------------------------------------
# 5. AMBIENTE E INFRAESTRUTURA
# -------------------------------------------------------------------------
# PORT: Porta onde o servidor Express irá rodar (Padrão: 3000).
# APP_URL: URL pública do seu sistema (Ex: https://aimee.vercel.app).
# NODE_ENV: 'development' para testes ou 'production' para o deploy final.

NODE_ENV=development
PORT=3000
APP_URL="http://localhost:3000"
