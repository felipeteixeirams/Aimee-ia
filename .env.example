# --- APP CONFIG ---
NODE_ENV=development
PORT=3000

# --- AI PROVIDERS ---
# Required for Gemini AI (Frontend/Backend)
GEMINI_API_KEY="your_gemini_api_key_here"

# Required if using DeepSeek provider
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# --- INFRASTRUCTURE ---
# The public URL of the application
APP_URL="http://localhost:3000"

# --- EMAIL (NODEMAILER) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="aimee@yourdomain.com"
SMTP_PASS="your_app_password"
ADMIN_EMAIL="felipeteixeirams@gmail.com"
