# --- APP CONFIG ---
NODE_ENV=development
PORT=3000

# --- AI PROVIDERS ---
# Required for Gemini AI (Frontend/Backend)
GEMINI_API_KEY="your_gemini_api_key_here"

# Required if using DeepSeek provider
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# --- INFRASTRUCTURE ---
# The public URL of the application
APP_URL="http://localhost:3000"

# --- EMAIL (NODEMAILER) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="aimee@yourdomain.com"
SMTP_PASS="your_app_password"
ADMIN_EMAIL="felipeteixeirams@gmail.com"

# --- GOOGLE OAUTH ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# The callback path should be /api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=

# --- GOOGLE MAPS ---
VITE_GOOGLE_MAPS_API_KEY=
