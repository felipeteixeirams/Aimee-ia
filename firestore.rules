rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') || 
        request.auth.token.email == 'felipeteixeirams@gmail.com'
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isAuthenticated() && (
        isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().status == 'approved')
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() < 100 &&
             data.displayName is string &&
             data.displayName.size() > 0 &&
             data.displayName.size() < 100 &&
             data.status in ['pending', 'approved', 'rejected', 'blocked'];
    }

    function isValidTask(data) {
      return data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.category is string &&
             data.status in ['todo', 'done'] &&
             (!('dueDate' in data) || (data.dueDate == null || (data.dueDate is string && data.dueDate.size() <= 50))) &&
             (!('time' in data) || (data.time == null || (data.time is string && data.time.size() <= 10))) &&
             (!('isAllDay' in data) || data.isAllDay is bool) &&
             (!('assignedTo' in data) || (data.assignedTo == null || (data.assignedTo is string && data.assignedTo.size() <= 100))) &&
             (!('participants' in data) || (data.participants == null || data.participants is list)) &&
             (!('recurrence' in data) || (data.recurrence == null || (
               data.recurrence.type in ['daily', 'weekly', 'monthly', 'annual'] &&
               (!('interval' in data.recurrence) || data.recurrence.interval is number) &&
               (!('daysOfWeek' in data.recurrence) || data.recurrence.daysOfWeek is list) &&
               (!('daysOfMonth' in data.recurrence) || data.recurrence.daysOfMonth is list) &&
               (!('month' in data.recurrence) || data.recurrence.month is number) &&
               (!('endTime' in data.recurrence) || (data.recurrence.endTime == null || data.recurrence.endTime is string)) &&
               (!('isInfinite' in data.recurrence) || data.recurrence.isInfinite is bool)
             ))) &&
             (!('recurrenceId' in data) || (data.recurrenceId == null || data.recurrenceId is string)) &&
             (!('originalDueDate' in data) || (data.originalDueDate == null || data.originalDueDate is string)) &&
             (!('note' in data) || (data.note == null || data.note is string));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && 
                    request.resource.data.status in ['pending', 'approved'] &&
                    (request.resource.data.status == 'pending' || isAdmin()) &&
                    isValidUser(request.resource.data);
      
      allow update: if (isOwner(userId) && isApproved() && isValidUser(request.resource.data)) ||
                    (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'blockedUntil']));

      match /transactions/{id} { allow read, write: if isApproved() && isOwner(userId); }
      match /shoppingList/{id} { allow read, write: if isApproved() && isOwner(userId); }
      match /chatHistory/{id} { allow read, write: if isApproved() && isOwner(userId); }
      match /goals/{id} { allow read, write: if isApproved() && isOwner(userId); }
      
      match /tasks/{id} { 
        allow read: if isApproved() && isOwner(userId); 
        allow create, update: if isApproved() && isOwner(userId) && isValidTask(request.resource.data);
        allow delete: if isApproved() && isOwner(userId);
      }
      
      match /events/{id} { allow read, write: if isApproved() && isOwner(userId); }
    }

    match /shares/{shareId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.sharedWithEmail == request.auth.token.email
      );
      allow create: if isApproved() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || resource.data.sharedWithEmail == request.auth.token.email);
    }

    match /config/global {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /users {
      allow list: if isAdmin();
    }
  }
}
